# Slack — Socket Mode requires both tokens
SLACK_BOT_TOKEN=        # xoxb-...
SLACK_APP_TOKEN=        # xapp-... (Socket Mode)
SLACK_CHANNEL_ALLOWED_LIST=          # CXXXX,CYYYY

# LLM — API key for the agent loop (provider TBD)
LLM_API_KEY=

# Database — path to SQLite file
DATABASE_URL=           # ./data/everwill.db

# Server
PORT=3000

# Optional
LOG_LEVEL=              #debug
