{
  "name": "everwill",
  "version": "0.1.0",
  "description": "Graph data release and deployment automation agent",
  "type": "module",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=.env.dev tsx watch src/server/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/server/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/bolt": "^4.3.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.0",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "xstate": "^5.19.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
